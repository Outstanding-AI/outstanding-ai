# =============================================================================
# LLM PROVIDER SELECTION
# =============================================================================
LLM_PROVIDER=vertex  # Primary: "vertex", Fallback: "openai"

# =============================================================================
# VERTEX AI CONFIGURATION (PRIMARY PROVIDER)
# =============================================================================
# Production uses AWS workload identity federation with the non-secret
# config file copied into the image at /app/infra/vertex-wif-config.json.
# Local dev can use ADC instead of ECS task-role credentials.
VERTEX_PROJECT_ID=production-493814
VERTEX_LOCATION=europe-west2
VERTEX_MODEL=gemini-2.5-flash
VERTEX_TEMPERATURE=0.3
VERTEX_MAX_TOKENS=8192
VERTEX_WIF_CONFIG_PATH=/app/infra/vertex-wif-config.json

# =============================================================================
# OPENAI CONFIGURATION (FALLBACK PROVIDER)
# =============================================================================
# Get your API key from: https://platform.openai.com/api-keys
# Note: gpt-5-nano is a reasoning model. Reasoning tokens consume from max_tokens
# budget, so max_tokens must be high enough to accommodate both reasoning and output.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-5-nano
OPENAI_TEMPERATURE=0.3
OPENAI_MAX_TOKENS=32768

# =============================================================================
# ANTHROPIC CONFIGURATION (OPTIONAL THIRD PROVIDER)
# =============================================================================
# Get your API key from: https://console.anthropic.com/settings/keys
# Anthropic is opt-in.
# ANTHROPIC_API_KEY=your-anthropic-api-key
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# ANTHROPIC_CLASSIFICATION_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_TEMPERATURE=0.3

# =============================================================================
# API CONFIGURATION
# =============================================================================
API_HOST=0.0.0.0
API_PORT=8001
DEBUG=false

# CORS - Comma-separated list of allowed origins
# Leave empty to allow all origins in debug mode
# Example: https://127.0.0.1:5000,http://localhost:3000
CORS_ALLOWED_ORIGINS=

# =============================================================================
# SERVICE AUTHENTICATION
# =============================================================================
# Shared secret for service-to-service calls (Django backend → AI service)
# When set, all requests (except /health) must include: Authorization: Bearer <token>
# Leave empty to disable auth (local development only)
SERVICE_AUTH_TOKEN=

# =============================================================================
# TIMEOUTS & RETRIES
# =============================================================================
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# =============================================================================
# RATE LIMITING (per-IP, per-minute)
# =============================================================================
# Higher limits for internal service-to-service calls
# RATE_LIMIT_CLASSIFY=100/minute
# RATE_LIMIT_GENERATE=100/minute
# RATE_LIMIT_GATES=100/minute

# =============================================================================
# LOGGING
# =============================================================================
LOG_LEVEL=INFO

# =============================================================================
# ECS FARGATE (Production only)
# =============================================================================
# Idle shutdown: exit after N seconds with no requests (0 = disabled)
# For ephemeral ECS tasks: set to 300 (5 min) so AI Engine exits after draft gen
# IDLE_SHUTDOWN_SECONDS=0
# For production: IDLE_SHUTDOWN_SECONDS=300
